FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Installer les dépendances + watchdog pour le rechargement du worker Celery
# (le code source est monté via volume)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt "watchdog[watchmedo]"

EXPOSE 6000

# La commande est surchargée par docker-compose.dev.yml selon le service
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "6000", "--reload"]
